---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/faq">FAQ</a>
      <a href="/contact">Contact</a>
      <a href="/join">Join</a>
    </div>
    <p class="copyright">&copy; {year} Hi-there.net. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #0f0f23;
    color: #888;
    padding: 1.5rem;
    text-align: center;
  }
  .footer-inner { max-width: 1200px; margin: 0 auto; }
  .footer-links { margin-bottom: 0.75rem; }
  .footer-links a {
    color: #aaa;
    text-decoration: none;
    margin: 0 0.75rem;
    font-size: 0.9rem;
  }
  .footer-links a:hover { color: #fff; }
  .copyright { margin: 0; font-size: 0.8rem; }
</style>
