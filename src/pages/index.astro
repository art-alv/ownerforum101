---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubHeader from '../components/SubHeader.astro';
import ContMenu from '../components/ContMenu.astro';
import ContContent from '../components/ContContent.astro';
import ContAdds from '../components/ContAdds.astro';
import SubFooter from '../components/SubFooter.astro';
---
<BaseLayout title="Home">
  <SubHeader
    title="Welcome to Hi-there.net"
    subtitle="Your resource hub for members across the country."
  />

  <div class="body-grid">
    <ContMenu />
    <ContContent title="Welcome">
      <section id="about">
        <h3>About</h3>
        <p>Hi-there.net is dedicated to providing information and resources for members in every state.</p>
      </section>
      <section id="services">
        <h3>Services</h3>
        <p>Browse state-specific guides, news, and community resources tailored to where you live.</p>
      </section>
      <section id="join">
        <h3>Join</h3>
        <p>Become a member today to unlock exclusive content and connect with others in your area.</p>
        <a href="/join" class="btn">Join Now</a>
      </section>
    </ContContent>
    <ContAdds />
  </div>

  <SubFooter />
</BaseLayout>

<style>
  .body-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    padding: 1.5rem;
    gap: 1rem;
  }
  .btn {
    display: inline-block;
    background: #e94560;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
  }
  .btn:hover { background: #c73652; }
</style>
