---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubHeader from '../../components/SubHeader.astro';
import ContMenu from '../../components/ContMenu.astro';
import ContContent from '../../components/ContContent.astro';
import ContAdds from '../../components/ContAdds.astro';
import SubFooter from '../../components/SubFooter.astro';
---
<BaseLayout title="Blog" description="Browse resources by state.">
  <SubHeader
    title="Member Blog"
    subtitle="Select your state to find local resources and news."
  />

  <div class="body-grid">
    <ContMenu />
    <ContContent title="Select a State">
      <p>Choose your state from the menu to view local news, resources, and community updates tailored to your area.</p>
    </ContContent>
    <ContAdds />
  </div>

  <SubFooter message="Find resources in your state — join today." />
</BaseLayout>

<style>
  .body-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    padding: 1.5rem;
    gap: 1rem;
  }
</style>
